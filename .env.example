# Qaithon credentials TEMPLATE — copy this file to `.env` and fill in the blanks.
# The real `.env` is gitignored; this template is checked in so contributors
# know what variables Qaithon recognizes.
#
# `qaithon.config.load_env()` reads `.env` automatically when imported.

# ---------------------------------------------------------------------------
# IBM Quantum Platform
# Where to get it:
#   1. Sign up at https://quantum.cloud.ibm.com
#   2. From the "Account settings" page, click "Identity and Access Management"
#      in the "Helpful links" panel (right side).
#   3. In IBM Cloud IAM (https://cloud.ibm.com/iam/apikeys), Create an API key.
#   4. Copy it once — you cannot view it again after closing the dialog.
# Cost: Open plan is free, 10 minutes of QPU time per month.
# ---------------------------------------------------------------------------
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_CHANNEL=ibm_quantum_platform
# Optional: explicit CRN. When unset, the runtime auto-selects the Open-plan instance.
# IBM_QUANTUM_INSTANCE=crn:v1:bluemix:public:quantum-computing:...

# ---------------------------------------------------------------------------
# AWS Braket
# Where to get it:
#   1. AWS Console → IAM → Users → Create user with AmazonBraketFullAccess.
#   2. Security credentials → Create access key → "CLI / Local code".
#   3. Copy both Access Key ID and Secret Access Key.
# Cost: requires a credit card on file. Free Tier ~1 h/month of SV1 simulator.
#        Real QPUs are pay-per-shot (~$0.30/task + $0.00075–$0.01/shot).
# ---------------------------------------------------------------------------
 AWS_ACCESS_KEY_ID=
 AWS_SECRET_ACCESS_KEY=
 AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Quandela Cloud
# Where to get it:
#   1. Apply at https://cloud.quandela.com (research-gated as of 2026).
#   2. Once approved, generate the token from the dashboard.
# Cost: free if approved; access is by application, not self-service.
# ---------------------------------------------------------------------------
 QUANDELA_TOKEN=

# ---------------------------------------------------------------------------
# HuggingFace Hub
# Where to get it:
#   1. Sign in at https://huggingface.co (free account).
#   2. Create the `qaithon` organization at https://huggingface.co/organizations/new
#      so the namespace is reserved before publishing.
#   3. Generate token at https://huggingface.co/settings/tokens — fine-grained
#      with "Write access to contents/settings of all repos under qaithon namespace".
# Cost: free.
# ---------------------------------------------------------------------------
 HF_TOKEN=hf_...
